### 智能工具选择算法
```python
async def select_mcp_tools(user_query: str, context: dict) -> List[str]:
    """基于用户查询智能选择MCP工具"""
    
    selected_tools = []
    query_lower = user_query.lower()
    
    # 分析查询类型
    if any(keyword in query_lower for keyword in ["分析", "统计", "数据", "趋势"]):
        selected_tools.extend([database_sqlite, calculator, quickchart])
        
    if any(keyword in query_lower for keyword in ["搜索", "研究", "最新", "信息"]):
        selected_tools.extend([brave_search, fetch])
        
    if any(keyword in query_lower for keyword in ["建议", "计划", "个性化", "定制"]):
        selected_tools.extend([memory, sequential_thinking])
        
    if any(keyword in query_lower for keyword in ["运动", "健身", "锻炼"]):
        selected_tools.extend([weather, time])
        
    if any(keyword in query_lower for keyword in ["计算", "算法", "公式"]):
        selected_tools.extend([calculator, run_python])
    
    # 去重并返回
    return list(set(selected_tools))
```

