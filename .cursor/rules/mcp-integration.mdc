    }

result = calculate_personalized_nutrition(30, 70, 175, 1.6)
print(result)
"""
nutrition_plan = await run_python.execute(algorithm_code)
```

## 🚀 智能自动化工作流

### 工作流 1: 全面健康评估
**触发关键词**: "健康评估", "分析数据", "健康状况"
```python
async def comprehensive_health_assessment(user_id: int):
    """全面健康评估自动工作流"""
    
    # Step 1: 并行获取基础数据
    user_profile = await memory.search_nodes(f"用户{user_id}健康画像")
    health_data = await database_sqlite.execute(
        "SELECT * FROM health_profiles WHERE user_id = ?", [user_id]
    )
    
    # Step 2: 计算健康指标
    if health_data:
        bmi = await calculator.calculate(f"{health_data.weight} / ({health_data.height/100} ** 2)")
        bmr = await calculator.calculate(f"88.362 + (13.397 * {health_data.weight}) + (4.799 * {health_data.height}) - (5.677 * {health_data.age})")
    
    # Step 3: 生成可视化报告
    chart = await quickchart.generate_chart({
        "type": "radar",
        "data": {
            "labels": ["BMI", "体脂率", "肌肉量", "心率", "睡眠质量"],
            "datasets": [{
                "label": "健康指标",
                "data": [bmi, 18, 35, 65, 85]
            }]
        }
    })
    
    # Step 4: AI深度分析
    analysis = await sequential_thinking.analyze(f"""
    用户健康数据分析：
    - BMI: {bmi}
    - 基础代谢率: {bmr}
    - 用户画像: {user_profile}
    请提供综合健康评估和改善建议
    """)
    
    return {
        "health_score": calculate_health_score(bmi, bmr),
        "visualization": chart,
        "ai_analysis": analysis,
        "recommendations": generate_recommendations(analysis)
    }
```

### 工作流 2: 智能营养规划
**触发关键词**: "营养计划", "饮食建议", "营养需求"
```python
async def intelligent_nutrition_planning(user_id: int, goals: List[str]):
    """智能营养规划工作流"""
    
    # Step 1: 搜索最新营养科学
    research = await brave_search.search("个性化营养 最新研究 2024")
    
    # Step 2: 获取用户数据和偏好
    user_data = await database_sqlite.execute(
        "SELECT * FROM users WHERE id = ?", [user_id]
    )
    preferences = await memory.search_nodes(f"用户{user_id}饮食偏好")
    
    # Step 3: 计算营养需求
    nutrition_calc = await run_python.execute(f"""
    def calculate_macro_needs(weight, height, age, activity, goals):
        bmr = 88.362 + (13.397 * {user_data.weight}) + (4.799 * {user_data.height}) - (5.677 * {user_data.age})
        tdee = bmr * {user_data.activity_level}
        
        if '减重' in {goals}:
            calories = tdee * 0.8
            protein = {user_data.weight} * 2.5
        elif '增肌' in {goals}:
            calories = tdee * 1.1
            protein = {user_data.weight} * 2.2
        else:
            calories = tdee
            protein = {user_data.weight} * 1.8
            
        return {{
            'calories': calories,
            'protein': protein,
            'carbs': calories * 0.4 / 4,
            'fat': calories * 0.3 / 9
        }}
    
    result = calculate_macro_needs({user_data.weight}, {user_data.height}, {user_data.age}, {user_data.activity_level}, {goals})
    """)
    
    # Step 4: 生成营养图表
    nutrition_chart = await quickchart.generate_chart({
        "type": "doughnut",
        "data": {
            "labels": ["蛋白质", "碳水化合物", "脂肪"],
            "datasets": [{
                "data": [nutrition_calc['protein'] * 4, nutrition_calc['carbs'] * 4, nutrition_calc['fat'] * 9]
            }]
        }
    })
    
    # Step 5: AI个性化建议
    recommendations = await sequential_thinking.analyze(f"""
    基于用户数据和营养需求：
    - 目标: {goals}
    - 营养需求: {nutrition_calc}
    - 饮食偏好: {preferences}
    - 最新研究: {research[:500]}
    
    请生成详细的个性化营养计划和食谱建议
    """)
    
    # Step 6: 保存计划到数据库
    await database_sqlite.execute("""
        INSERT INTO nutrition_plans (user_id, goals, calories, protein, carbs, fat, created_at)
        VALUES (?, ?, ?, ?, ?, ?, datetime('now'))
    """, [user_id, ','.join(goals), nutrition_calc['calories'], nutrition_calc['protein'], 
          nutrition_calc['carbs'], nutrition_calc['fat']])
    
    return {
        "nutrition_needs": nutrition_calc,
        "chart": nutrition_chart,
        "personalized_plan": recommendations,
        "scientific_basis": research
    }
```

