## 📈 MCP工具使用最佳实践

### 1. 并行调用优化
```python
# ✅ 好的做法：并行调用相关工具
async def parallel_health_analysis():
    tasks = [
        database_sqlite.query("SELECT * FROM health_profiles"),
        weather.get_current_weather(),
        time.get_current_time()
    ]
    results = await asyncio.gather(*tasks)
    return results

# ❌ 避免：串行调用
async def sequential_calls():  # 避免这种做法
    data = await database_sqlite.query("SELECT * FROM health_profiles")
    weather = await weather.get_current_weather()
    time = await time.get_current_time()
```

### 2. 错误处理策略
```python
async def robust_mcp_call(tool_func, *args, **kwargs):
    """带重试和降级的MCP工具调用"""
    
    max_retries = 3
    for attempt in range(max_retries):
        try:
            return await tool_func(*args, **kwargs)
        except TimeoutError:
            if attempt < max_retries - 1:
                await asyncio.sleep(2 ** attempt)  # 指数退避
                continue
            else:
                return {"error": "Tool timeout after retries"}
        except Exception as e:
            logger.error(f"MCP tool error: {e}")
            return {"error": str(e)}
```

