# 运行个性化营养需求算法
algorithm_code = """
import numpy as np
def calculate_personalized_nutrition(age, weight, height, activity_level):
    # 复杂营养需求计算算法
    bmr = 88.362 + (13.397 * weight) + (4.799 * height) - (5.677 * age)
    tdee = bmr * activity_level
    return {
        'calories': tdee,
        'protein': weight * 2.2,  # g
        'carbs': tdee * 0.45 / 4,  # g
